{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "useDefineForClassFields": true,
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "types": [
      "vite/client"
    ],
    "baseUrl": ".",
    "paths": {
      "@trust-governance/shared": [
        "../shared/src/index.ts"
      ],
      "@trust-governance/shared/*": [
        "../shared/src/*"
      ]
    }
  },
  "include": [
    "src"
  ]
}