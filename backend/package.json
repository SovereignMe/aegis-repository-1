{
  "name": "trust-governance-app-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/backend/src/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "rm -f ./data/test-state.json && STATE_FILE=./data/test-state.json AEGIS_TEST_MODE=1 tsx --test --test-concurrency=1 test/**/*.test.ts",
    "migrate": "tsx src/scripts/migrate.ts up",
    "migrate:down": "tsx src/scripts/migrate.ts down",
    "ops:backup-drill": "tsx src/scripts/backup-restore-drill.ts",
    "verify:bundle": "tsx src/scripts/verify-bundle.ts",
    "keys:rotate": "tsx src/scripts/rotate-managed-key.ts",
    "test:load:auth": "node ./test/load/auth-upload.load.mjs",
    "test:load:upload": "node ./test/load/document-upload.load.mjs",
    "test:restore-drill": "node ./test/restore-drill.assert.mjs"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.3",
    "@types/node": "^22.7.4",
    "dotenv": "^17.4.1",
    "fastify": "^5.0.0",
    "jose": "^5.10.0",
    "pg": "^8.12.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/pg": "^8.11.10",
    "eslint": "^9.24.0",
    "globals": "^15.15.0",
    "typescript-eslint": "^8.29.1"
  }
}