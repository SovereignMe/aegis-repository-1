{
  "name": "@trust-governance/shared",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./permissions": {
      "types": "./dist/permissions.d.ts",
      "default": "./dist/permissions.js"
    },
    "./domain": {
      "types": "./dist/domain.d.ts",
      "default": "./dist/domain.js"
    },
    "./policy": {
      "types": "./dist/policy.d.ts",
      "default": "./dist/policy.js"
    }
  },
  "files": [
    "dist",
    "policies",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "node -e \"process.exit(0)\"",
    "test": "node -e \"process.exit(0)\""
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
